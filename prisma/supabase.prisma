generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  FIELD_OFFICER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  AT_RISK
  DROPPED_OUT
  MIGRATED
  GRADUATED
}

enum DBTStatus {
  ELIGIBLE
  DOCUMENTS_PENDING
  VERIFIED
  DISBURSED
  CONFIRMED
  REJECTED
}

enum DocumentType {
  AADHAAR
  BANK_PASSBOOK
  CASTE_CERTIFICATE
  MARKSHEET
  PHOTO
  OTHER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationChannel {
  SMS
  WHATSAPP
  EMAIL
  IN_APP
}

model User {
  id           String        @id @default(cuid())
  clerkUserId  String        @unique
  name         String
  email        String        @unique
  role         Role          @default(FIELD_OFFICER)
  district     String
  phone        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  students     Student[]     @relation("AssignedOfficer")
  activityLogs ActivityLog[]
}

model Student {
  id                String             @id @default(cuid())
  name              String
  dob               DateTime
  gender            Gender
  tribe             String
  aadhaarLast4      String?
  guardianName      String
  guardianPhone     String?
  school            String
  currentClass      String
  district          String
  village           String
  status            StudentStatus      @default(ACTIVE)
  assignedOfficerId String
  assignedOfficer   User               @relation("AssignedOfficer", fields: [assignedOfficerId], references: [id])
  attendanceRecords AttendanceRecord[]
  marksRecords      MarksRecord[]
  dbtRecords        DBTRecord[]
  migrationRecords  MigrationRecord[]
  documents         Document[]
  riskScore         DropoutRiskScore?
  activityLogs      ActivityLog[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // New Fields
  isTribal          Boolean            @default(true)
  photoUrl          String?
  goesToTuition     Boolean            @default(false)
  achievements      Achievement[]
  tuitionAttendance TuitionAttendance[]
}

model AttendanceRecord {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  month        Int
  year         Int
  daysPresent  Int
  daysTotal    Int
  percentage   Float
  recordedById String
  createdAt    DateTime @default(now())
}

model MarksRecord {
  id            String   @id @default(cuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  term          String
  subject       String
  marksObtained Float
  marksTotal    Float
  academicYear  String
  createdAt     DateTime @default(now())
}

model DBTRecord {
  id               String     @id @default(cuid())
  studentId        String
  student          Student    @relation(fields: [studentId], references: [id])
  scholarshipName  String
  amount           Float
  status           DBTStatus  @default(ELIGIBLE)
  bankAccountLast4 String?
  appliedDate      DateTime?
  verifiedDate     DateTime?
  disbursedDate    DateTime?
  confirmedDate    DateTime?
  remarks          String?
  updatedById      String
  createdAt        DateTime   @default(now())
}

model MigrationRecord {
  id           String    @id @default(cuid())
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id])
  fromDistrict String
  toDistrict   String
  reason       String
  startDate    DateTime
  endDate      DateTime?
  newOfficerId String?
  createdAt    DateTime  @default(now())
}

model Document {
  id           String       @id @default(cuid())
  studentId    String
  student      Student      @relation(fields: [studentId], references: [id])
  type         DocumentType
  fileUrl      String
  uploadedById String
  createdAt    DateTime     @default(now())
}

model DropoutRiskScore {
  id           String    @id @default(cuid())
  studentId    String    @unique
  student      Student   @relation(fields: [studentId], references: [id])
  score        Float
  level        RiskLevel
  factors      Json
  calculatedAt DateTime  @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])
  metadata  Json?
  timestamp DateTime @default(now())
}

model Notification {
  id        String              @id @default(cuid())
  studentId String?
  officerId String?
  channel   NotificationChannel
  message   String
  status    String
  sentAt    DateTime            @default(now())
}

model Achievement {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title       String   // e.g. "1st place in 100m race"
  event       String   // e.g. "Annual Day Functions"
  award       String?  // e.g. "Trophy", "Certificate"
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model TuitionAttendance {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date         DateTime
  status       String   // "PRESENT" or "ABSENT"
  recordedById String
  createdAt    DateTime @default(now())

  @@unique([studentId, date])
}
